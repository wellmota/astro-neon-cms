---
export const prerender = false;
import AdminLayout from '@/layouts/AdminLayout.astro';
import Toast from '@/components/admin/Toast.astro';

const user = Astro.locals.user!;
const erro = Astro.url.searchParams.get('erro');
const ok = Astro.url.searchParams.get('ok');
const inputCls =
  'w-full rounded-lg border border-neutral-700 bg-neutral-900 px-3 py-2.5 text-sm text-neutral-100 outline-none transition placeholder:text-neutral-500 focus:border-[#3b6fe0] focus:ring-2 focus:ring-[#0040C8]/35';
const labelCls = 'mb-1 block text-sm font-medium text-neutral-300';
---

<AdminLayout title="Minha conta" user={user}>
  <div class="mx-auto max-w-md">
    <h1 class="mb-1 text-xl font-bold tracking-tight">Minha conta</h1>
    <p class="mb-6 text-sm text-neutral-400">{user.name}</p>

    {
      user.reset && (
        <p class="mb-4 rounded-lg border border-amber-900/60 bg-amber-950/40 px-3 py-2 text-sm text-amber-300">
          Este é seu primeiro acesso. Defina uma nova senha para continuar.
        </p>
      )
    }
    {
      erro && (
        <Toast
          type="error"
          message={
            erro === 'atual'
              ? 'Senha atual incorreta.'
              : erro === 'curta'
                ? 'A nova senha precisa ter ao menos 8 caracteres.'
                : 'As senhas não conferem.'
          }
        />
      )
    }
    {ok && <Toast message="Senha atualizada." />}

    <div class="rounded-xl border border-neutral-800 bg-neutral-900/60 p-6">
      <form method="POST" action="/api/admin/senha" class="space-y-4">
        <div>
          <label class={labelCls} for="atual">Senha atual</label>
          <input id="atual" name="atual" type="password" required autocomplete="current-password" class={inputCls} />
        </div>
        <div>
          <label class={labelCls} for="nova">Nova senha</label>
          <input id="nova" name="nova" type="password" required minlength="8" autocomplete="new-password" class={inputCls} />
        </div>
        <div>
          <label class={labelCls} for="confirmar">Confirmar nova senha</label>
          <input id="confirmar" name="confirmar" type="password" required minlength="8" autocomplete="new-password" class={inputCls} />
        </div>
        <button type="submit"
          class="w-full rounded-lg bg-[#0040C8] px-3 py-2.5 text-sm font-semibold text-white hover:bg-[#1b50d6]">
          Salvar nova senha
        </button>
      </form>
    </div>
  </div>
</AdminLayout>
