---
export const prerender = false;
import AdminLayout from '@/layouts/AdminLayout.astro';
import { config, titleOf } from '@/lib/cms';
import { listForAdmin } from '@/lib/entries';

const user = Astro.locals.user!;

const loaded = await Promise.all(
  config.collections.map(async (col) => ({ col, rows: await listForAdmin(col.name) })),
);

const stats = loaded.map(({ col, rows }) => ({
  label: col.label,
  href: `/admin/${col.name}`,
  pub: rows.filter((r) => !r.draft).length,
  draft: rows.filter((r) => r.draft).length,
  total: rows.length,
}));

const recent = loaded
  .flatMap(({ col, rows }) =>
    rows.map((r) => ({
      type: col.labelSingular ?? col.label,
      title: titleOf(col, r.data),
      href: `/admin/${col.name}/${r.id}`,
      at: r.updated_at,
      by: r.updated_by_name,
    })),
  )
  .sort((a, b) => new Date(b.at).getTime() - new Date(a.at).getTime())
  .slice(0, 8);

const fmt = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
const card = 'rounded-xl border border-neutral-800 bg-neutral-900/60 p-5';
---

<AdminLayout title="Início" user={user} wide>
  <div class="mb-6">
    <h1 class="text-xl font-bold tracking-tight">Olá, {user.name.split(' ')[0]}</h1>
    <p class="mt-0.5 text-sm text-neutral-400">Visão geral do conteúdo.</p>
  </div>

  <p class="mb-6 flex items-start gap-2 rounded-lg border border-neutral-800 bg-neutral-900/60 px-3 py-2 text-sm text-neutral-400">
    <svg class="mt-0.5 size-4 shrink-0 text-[#7aa0ff]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
    <span>Publicar é só desmarcar “Rascunho” e salvar. O conteúdo publicado fica disponível na API pública (<code>/api/content/…</code>).</span>
  </p>

  <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
    {stats.map((s) => (
      <a href={s.href} class={`${card} cursor-pointer transition-colors hover:border-neutral-700 hover:bg-neutral-900`}>
        <p class="text-xs font-medium uppercase tracking-wider text-neutral-500">{s.label}</p>
        <p class="mt-2 text-3xl font-bold tabular-nums text-green-300">{s.pub}</p>
        <p class="mt-1 text-xs text-neutral-500">{s.total} no total · {s.draft} rascunho(s)</p>
      </a>
    ))}
    <a href="/admin/midia" class={`${card} flex items-center gap-3 transition-colors hover:border-neutral-700 hover:bg-neutral-900`}>
      <svg class="size-5 shrink-0 text-[#7aa0ff]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
      <span class="text-sm font-medium text-neutral-200">Biblioteca de mídia</span>
    </a>
  </div>

  <div class="mt-6">
    <h2 class="mb-3 text-sm font-semibold text-neutral-200">Editado recentemente</h2>
    {recent.length === 0 ? (
      <p class="text-sm text-neutral-400">Nada por aqui ainda.</p>
    ) : (
      <div class="overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900/40">
        <ul class="divide-y divide-neutral-800/70">
          {recent.map((r) => (
            <li>
              <a href={r.href} class="flex items-center gap-3 px-4 py-3 transition-colors hover:bg-neutral-900/60">
                <span class="shrink-0 rounded bg-neutral-800 px-2 py-0.5 text-[11px] font-medium text-neutral-400">{r.type}</span>
                <span class="min-w-0 flex-1 truncate text-sm text-neutral-100">{r.title}</span>
                <span class="hidden shrink-0 text-xs text-neutral-500 sm:inline">{r.by ?? '—'}</span>
                <span class="shrink-0 whitespace-nowrap text-xs text-neutral-500">{fmt.format(new Date(r.at))}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</AdminLayout>
