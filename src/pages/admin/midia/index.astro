---
export const prerender = false;
import AdminLayout from '@/layouts/AdminLayout.astro';
import Toast from '@/components/admin/Toast.astro';
import { list } from '@vercel/blob';

const user = Astro.locals.user!;
const ok = Astro.url.searchParams.get('ok');

const token = process.env.BLOB_READ_WRITE_TOKEN ?? import.meta.env.BLOB_READ_WRITE_TOKEN;

type Item = { url: string; pathname: string; size: number; uploadedAt: string };
let items: Item[] = [];
let erroLista: string | null = null;

if (!token) {
  erroLista = 'BLOB_READ_WRITE_TOKEN não configurado neste ambiente.';
} else {
  try {
    const { blobs } = await list({ token, limit: 1000 });
    items = blobs
      .map((b) => ({ url: b.url, pathname: b.pathname, size: b.size, uploadedAt: String(b.uploadedAt) }))
      .sort((a, b) => new Date(b.uploadedAt).getTime() - new Date(a.uploadedAt).getTime());
  } catch (e) {
    erroLista = (e as Error).message;
  }
}

const fmtSize = (n: number) => (n < 1024 * 1024 ? `${Math.max(1, Math.round(n / 1024))} KB` : `${(n / 1024 / 1024).toFixed(1)} MB`);
const basename = (p: string) => p.split('/').pop() ?? p;
const card = 'rounded-xl border border-neutral-800 bg-neutral-900/60';
---

<AdminLayout title="Mídia" user={user} wide>
  <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-xl font-bold tracking-tight">Biblioteca de mídia</h1>
      <p class="mt-0.5 text-sm text-neutral-400">{items.length} {items.length === 1 ? 'arquivo' : 'arquivos'} no Vercel Blob.</p>
    </div>
    <label class="flex cursor-pointer items-center gap-2 rounded-lg bg-[#0040C8] px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-[#1b50d6]">
      <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M17 8l-5-5-5 5"/><path d="M12 3v12"/></svg>
      <span data-upload-label>Enviar imagens</span>
      <input type="file" accept="image/*" multiple data-upload-input hidden />
    </label>
  </div>

  {ok === 'excluido' && <Toast message="Arquivo excluído." type="info" />}
  {ok === 'erro' && <Toast message="Não foi possível excluir o arquivo." type="error" />}
  <p data-upload-status class="mb-4 hidden rounded-lg border border-neutral-800 bg-neutral-900 px-3 py-2 text-sm text-neutral-300"></p>

  {erroLista && <p class="mb-4 rounded-lg border border-amber-900/60 bg-amber-950/40 px-3 py-2 text-sm text-amber-300">{erroLista}</p>}

  {
    !erroLista && items.length > 0 && (
      <input
        type="search"
        id="midia-search"
        placeholder="Buscar por nome do arquivo…"
        class="mb-4 w-full max-w-sm rounded-lg border border-neutral-700 bg-neutral-900 px-3 py-1.5 text-sm text-neutral-100 outline-none transition placeholder:text-neutral-500 focus:border-[#3b6fe0] focus:ring-2 focus:ring-[#0040C8]/35"
      />
    )
  }

  {
    !erroLista && items.length === 0 ? (
      <div class={`${card} flex flex-col items-center justify-center gap-2 p-12 text-center`}>
        <p class="text-sm text-neutral-300">Nenhuma imagem ainda.</p>
        <p class="text-xs text-neutral-500">Use “Enviar imagens” acima, ou os campos de imagem nos editores de post/case.</p>
      </div>
    ) : (
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
        {items.map((it) => (
          <div class={`${card} group overflow-hidden`} data-search={basename(it.pathname).toLowerCase()}>
            <div class="relative aspect-square bg-neutral-950">
              <img src={it.url} alt={basename(it.pathname)} loading="lazy" class="h-full w-full object-cover" />
              <div class="pointer-events-none absolute inset-0 flex items-start justify-end gap-1.5 bg-gradient-to-b from-black/50 to-transparent p-2 opacity-0 transition-opacity group-hover:opacity-100">
                <button
                  type="button"
                  data-copy={it.url}
                  aria-label="Copiar URL"
                  title="Copiar URL"
                  class="pointer-events-auto flex size-8 cursor-pointer items-center justify-center rounded-md bg-neutral-900/90 text-neutral-200 transition-colors hover:bg-neutral-800"
                >
                  <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                </button>
                <form method="POST" action="/api/admin/midia" class="pointer-events-auto" onsubmit="return confirm('Excluir esta imagem? Posts/cases que a usam ficarão sem ela.')">
                  <input type="hidden" name="url" value={it.url} />
                  <button
                    type="submit"
                    aria-label="Excluir"
                    title="Excluir"
                    class="flex size-8 cursor-pointer items-center justify-center rounded-md bg-neutral-900/90 text-red-300 transition-colors hover:bg-red-950"
                  >
                    <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                </form>
              </div>
            </div>
            <div class="p-2.5">
              <p class="truncate text-xs font-medium text-neutral-200" title={basename(it.pathname)}>{basename(it.pathname)}</p>
              <p class="mt-0.5 text-[11px] text-neutral-500">{fmtSize(it.size)}</p>
            </div>
          </div>
        ))}
      </div>
    )
  }
</AdminLayout>

<script>
  import { upload } from '@vercel/blob/client';

  // Busca client-side por nome de arquivo.
  const q = document.getElementById('midia-search') as HTMLInputElement | null;
  q?.addEventListener('input', () => {
    const term = q.value.trim().toLowerCase();
    document.querySelectorAll<HTMLElement>('[data-search]').forEach((el) => {
      el.style.display = !term || (el.dataset.search ?? '').includes(term) ? '' : 'none';
    });
  });

  // Copiar URL pública.
  document.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-copy]');
    if (!btn) return;
    try {
      await navigator.clipboard.writeText(btn.dataset.copy ?? '');
      const original = btn.innerHTML;
      btn.innerHTML = '<svg class="size-4 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';
      setTimeout(() => (btn.innerHTML = original), 1200);
    } catch {
      /* clipboard indisponível */
    }
  });

  // Upload (client → Vercel Blob), múltiplos arquivos, recarrega ao terminar.
  const input = document.querySelector<HTMLInputElement>('[data-upload-input]');
  const label = document.querySelector<HTMLElement>('[data-upload-label]');
  const status = document.querySelector<HTMLElement>('[data-upload-status]');
  input?.addEventListener('change', async () => {
    const files = Array.from(input.files ?? []);
    if (!files.length) return;
    const labelText = label?.textContent ?? 'Enviar imagens';
    if (status) {
      status.classList.remove('hidden');
      status.textContent = `Enviando 0/${files.length}…`;
    }
    try {
      for (let i = 0; i < files.length; i++) {
        if (label) label.textContent = `Enviando ${i + 1}/${files.length}…`;
        if (status) status.textContent = `Enviando ${i + 1}/${files.length}…`;
        await upload(files[i].name, files[i], { access: 'public', handleUploadUrl: '/api/admin/upload' });
      }
      if (status) status.textContent = 'Concluído. Atualizando…';
      location.reload();
    } catch (err) {
      if (status) status.textContent = 'Falha no upload: ' + ((err as Error)?.message ?? err);
      if (label) label.textContent = labelText;
      input.value = '';
    }
  });
</script>
