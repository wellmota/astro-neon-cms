# Postgres (Neon recomendado). Crie o schema com schema.sql.
DATABASE_URL="postgresql://USER:PASS@HOST/db?sslmode=require"

# Segredo pra assinar o cookie de sessão. Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="troque-por-uma-string-aleatoria-longa"

# Upload de imagens (Vercel Blob). Vercel → Storage → seu store → tokens.
# Opcional: sem ele, os campos de imagem ainda aceitam colar uma URL.
BLOB_READ_WRITE_TOKEN=""
